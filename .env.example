# Auto-populated by Vercel when you add the "Postgres" storage integration
# to your project (Storage tab -> Create Database -> Postgres). No manual
# migration needed — the app creates its own table on first request.
#
# For local development: copy this file to .env.local and paste in the
# values from Vercel (Storage -> your DB -> .env.local tab), or point at
# any Postgres instance you have.

POSTGRES_URL="postgres://user:password@host/db?sslmode=require"
